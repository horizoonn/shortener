SHORTENER_ENVIRONMENT=development
SHORTENER_TIME_ZONE=UTC
SHORTENER_LOG_LEVEL=DEBUG
SHORTENER_LOG_FOLDER=.out/logs
SHORTENER_HTTP_ADDR=:8080
SHORTENER_HTTP_SHUTDOWN_TIMEOUT=10s
SHORTENER_HTTP_READ_HEADER_TIMEOUT=5s
SHORTENER_HTTP_READ_TIMEOUT=10s
SHORTENER_HTTP_WRITE_TIMEOUT=10s
SHORTENER_HTTP_IDLE_TIMEOUT=60s
SHORTENER_HTTP_ALLOWED_ORIGINS=*
SHORTENER_HTTP_ALLOWED_METHODS=GET,POST,OPTIONS

SHORTENER_DATABASE_URL=postgres://shortener:shortener@localhost:5432/shortener?sslmode=disable
SHORTENER_REDIS_ADDR=localhost:6379
SHORTENER_REDIS_PASSWORD=
SHORTENER_REDIS_DB=0
SHORTENER_REDIS_CACHE_TTL=10m

POSTGRES_DB=shortener
POSTGRES_USER=shortener
POSTGRES_PASSWORD=shortener
POSTGRES_PORT=5432
REDIS_PORT=6379
SHORTENER_PORT=8080
